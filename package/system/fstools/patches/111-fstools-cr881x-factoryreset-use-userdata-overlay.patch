+static char *find_ubi_mount_point(struct volume *v)
+{
+	char path[PATH_MAX], name[128], blk[160];
+	int ubi, vol;
+
+	if (!v || !v->blk)
+		return NULL;
+
+	if (sscanf(v->blk, "/dev/ubi%d_%d", &ubi, &vol) != 2)
+		return NULL;
+
+	snprintf(path, sizeof(path), SYS_UBI_PATH "/ubi%d_%d/name", ubi, vol);
+	if (read_line(path, name, sizeof(name)))
+		return NULL;
+
+	snprintf(blk, sizeof(blk), "ubi%d:%s", ubi, name);
+	return find_mount_point(blk, 1);
+}
