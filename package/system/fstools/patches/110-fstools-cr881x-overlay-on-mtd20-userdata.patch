+#define DT_COMPATIBLE_PATH      "/proc/device-tree/compatible"
+#define PROC_MTD_PATH           "/proc/mtd"
+#define SYS_UBI_PATH            "/sys/class/ubi"
+#define UBIATTACH_BIN           "/usr/sbin/ubiattach"
+#define UBIMKVOL_BIN            "/usr/sbin/ubimkvol"
+
+static int xiaomi_overlay_prepared = -1;
+static int xiaomi_overlay_ubi = -1;
+static char xiaomi_overlay_mount_src[32];
+
 #define BUFLEN 64
 
+static int read_line(const char *path, char *buf, size_t len)
+{
+	FILE *f;
+
+	if (!buf || !len)
+		return -1;
+
+	f = fopen(path, "r");
+	if (!f)
+		return -1;
+
+	if (!fgets(buf, len, f)) {
+		fclose(f);
+		return -1;
+	}
+	fclose(f);
+
+	buf[strcspn(buf, "\r\n")] = '\0';
+	return 0;
+}
+
+static int run_quiet(const char *fmt, ...)
+{
+	char cmd[256];
+	va_list ap;
+
+	va_start(ap, fmt);
+	vsnprintf(cmd, sizeof(cmd), fmt, ap);
+	va_end(ap);
+
+	return system(cmd);
+}
+
+static bool is_xiaomi_ipq50xx_overlay_board(void)
+{
+	FILE *f;
+	char buf[256];
+	size_t n, i;
+
+	f = fopen(DT_COMPATIBLE_PATH, "rb");
+	if (!f)
+		return false;
+
+	n = fread(buf, 1, sizeof(buf), f);
+	fclose(f);
+	if (!n)
+		return false;
+
+	for (i = 0; i + sizeof("xiaomi,cr881x") - 1 <= n; i++) {
+		if (!memcmp(buf + i, "xiaomi,cr881x", sizeof("xiaomi,cr881x") - 1))
+			return true;
+		if (!memcmp(buf + i, "redmi,ax3000", sizeof("redmi,ax3000") - 1))
+			return true;
+	}
+
+	return false;
+}
+
+static int find_mtd_index(const char *name)
+{
+	FILE *f;
+	char line[256], label[128];
+	int idx;
+
+	f = fopen(PROC_MTD_PATH, "r");
+	if (!f)
+		return -1;
+
+	while (fgets(line, sizeof(line), f)) {
+		if (sscanf(line, "mtd%d: %*x %*x \"%127[^\"]\"", &idx, label) != 2)
+			continue;
+		if (!strcmp(label, name)) {
+			fclose(f);
+			return idx;
+		}
+	}
+
+	fclose(f);
+	return -1;
+}
+
+static int find_ubi_num_by_mtd(int mtdnum)
+{
+	DIR *d;
+	struct dirent *de;
+	char path[PATH_MAX], line[32];
+	int ubi;
+
+	d = opendir(SYS_UBI_PATH);
+	if (!d)
+		return -1;
+
+	while ((de = readdir(d)) != NULL) {
+		if (sscanf(de->d_name, "ubi%d", &ubi) != 1)
+			continue;
+
+		snprintf(path, sizeof(path), SYS_UBI_PATH "/%s/mtd_num", de->d_name);
+		if (read_line(path, line, sizeof(line)))
+			continue;
+
+		if (atoi(line) == mtdnum) {
+			closedir(d);
+			return ubi;
+		}
+	}
+
+	closedir(d);
+	return -1;
+}
+
+static bool ubi_volume_exists_on_ubi(int ubi_num, const char *name)
+{
+	DIR *d;
+	struct dirent *de;
+	char path[PATH_MAX], vname[128];
+	int dev, vol;
+
+	d = opendir(SYS_UBI_PATH);
+	if (!d)
+		return false;
+
+	while ((de = readdir(d)) != NULL) {
+		if (sscanf(de->d_name, "ubi%d_%d", &dev, &vol) != 2)
+			continue;
+		if (dev != ubi_num)
+			continue;
+
+		snprintf(path, sizeof(path), SYS_UBI_PATH "/%s/name", de->d_name);
+		if (read_line(path, vname, sizeof(vname)))
+			continue;
+		if (!strcmp(vname, name)) {
+			closedir(d);
+			return true;
+		}
+	}
+
+	closedir(d);
+	return false;
+}
+
+static int ensure_xiaomi_overlay_userdata(void)
+{
+	int mtdnum, ubi;
+
+	if (!is_xiaomi_ipq50xx_overlay_board())
+		return -1;
+
+	mtdnum = find_mtd_index("overlay");
+	if (mtdnum < 0)
+		return -1;
+
+	ubi = find_ubi_num_by_mtd(mtdnum);
+	if (ubi < 0) {
+		if (!run_quiet(UBIATTACH_BIN " -m %d >/dev/null 2>&1", mtdnum))
+			ubi = find_ubi_num_by_mtd(mtdnum);
+	}
+	if (ubi >= 0) {
+		xiaomi_overlay_ubi = ubi;
+		snprintf(xiaomi_overlay_mount_src, sizeof(xiaomi_overlay_mount_src),
+			 "ubi%d:userdata", ubi);
+	}
+
+	if (ubi >= 0 && ubi_volume_exists_on_ubi(ubi, "userdata"))
+		return 0;
+
+	if (ubi >= 0 &&
+	    !run_quiet(UBIMKVOL_BIN " /dev/ubi%d -N userdata -m >/dev/null 2>&1",
+		       ubi))
+		return 0;
+
+	return -1;
+}
+
+static void overlay_volume_fixup(struct volume *v)
+{
+	if (!v || !v->name || strcmp(v->name, "userdata"))
+		return;
+
+	if (xiaomi_overlay_ubi < 0 || !xiaomi_overlay_mount_src[0])
+		return;
+
+	free(v->blk);
+	v->blk = strdup(xiaomi_overlay_mount_src);
+}
+
+static struct volume *overlay_volume_find_start(const char *fallback_name)
+{
+	struct volume *v;
+
+	if (xiaomi_overlay_prepared < 0)
+		xiaomi_overlay_prepared = ensure_xiaomi_overlay_userdata();
+
+	if (xiaomi_overlay_prepared == 0) {
+		v = volume_find("userdata");
+		if (v)
+			return v;
+	}
+
+	return volume_find((char *)(fallback_name ? fallback_name : "rootfs_data"));
+}
+
+static struct volume *overlay_volume_find_done(void)
+{
+	struct volume *v;
+
+	if (xiaomi_overlay_prepared < 0)
+		xiaomi_overlay_prepared = ensure_xiaomi_overlay_userdata();
+
+	if (xiaomi_overlay_prepared == 0) {
+		v = volume_find("userdata");
+		if (v)
+			return v;
+	}
+
+	return volume_find("rootfs_data");
+}
