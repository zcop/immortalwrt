#!/usr/bin/ucode

'use strict';

const path = '/var/run/uboot-env/';

import * as fs from 'fs';

if (fs.lsdir(path)) {
	warn(`env has already been loaded to ${path}\n`);
	exit(0);
}

/*
 * Skip loading when no env config is available yet (e.g. early boot before
 * overlay/config is ready), so fw_printenv doesn't emit noisy warnings.
 */
let cmd = null;

if (fs.stat('/etc/fw_env.config'))
	cmd = 'fw_printenv 2>/dev/null';
else if (fs.stat('/etc/fw_sys.config'))
	cmd = 'fw_printenv -c /etc/fw_sys.config 2>/dev/null';
else
	exit(0);

let fp = fs.popen(cmd);
let raw = fp.read('all');
fp.close();

if (!length(raw))
	exit(0);

fs.mkdir(path);
for (let line in split(raw, '\n')) {
	let vals = split(line, '=');
	if (vals[0] && vals[1])
		fs.writefile(path + vals[0], vals[1]);
}
