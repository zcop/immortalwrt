#!/bin/sh /etc/rc.common

START=99

. /lib/functions.sh

wait_for_overlay() {
	local timeout=10

	while [ "$timeout" -gt 0 ]; do
		grep -q ' /overlay ' /proc/mounts && return 0
		sleep 1
		timeout=$((timeout - 1))
	done

	return 1
}

set_bootenv_var() {
	local name="$1"
	local value="$2"

	if ! fw_setenv "$name" "$value"; then
		logger -t uboot_env "failed to set $name=$value"
		return 1
	fi

	return 0
}

update_xiaomi_bootenv() {
	local mtd="$1"
	local current
	local update=0

	case "$mtd" in
		rootfs)
			current=0
			;;
		rootfs_1)
			current=1
			;;
		*)
			echo "Unable to determine UBIPART: ubi.mtd=$mtd"
			return 1
			;;
	esac

	[ "$(fw_printenv -n flag_boot_rootfs 2>/dev/null)" = "$current" ] || update=1
	[ "$(fw_printenv -n flag_last_success 2>/dev/null)" = "$current" ] || update=1
	[ "$(fw_printenv -n flag_boot_success 2>/dev/null)" = "1" ] || update=1
	[ "$(fw_printenv -n flag_ota_reboot 2>/dev/null)" = "0" ] || update=1
	[ "$(fw_printenv -n flag_try_sys1_failed 2>/dev/null)" = "0" ] || update=1
	[ "$(fw_printenv -n flag_try_sys2_failed 2>/dev/null)" = "0" ] || update=1

	[ "$update" -eq 0 ] && return 0

	logger -t uboot_env "repairing Xiaomi boot flags for $mtd"

	set_bootenv_var flag_boot_rootfs "$current" || return 1
	set_bootenv_var flag_last_success "$current" || return 1
	set_bootenv_var flag_boot_success 1 || return 1
	set_bootenv_var flag_ota_reboot 0 || return 1
	set_bootenv_var flag_try_sys1_failed 0 || return 1
	set_bootenv_var flag_try_sys2_failed 0 || return 1

	return 0
}

boot() {
	case $(board_name) in
		redmi,ax3000|\
		xiaomi,cr881x)
			wait_for_overlay || {
				logger -t uboot_env "overlay not ready, skip"
				return 0
			}
			[ -s /etc/fw_env.config ] || {
				logger -t uboot_env "fw_env.config missing, skip"
				return 0
			}
			fw_printenv >/dev/null || {
				logger -t uboot_env "fw_printenv failed, skip"
				return 0
			}

			local mtd="$(grep -oE 'ubi.mtd=[a-zA-Z0-9\-\_]*' /proc/cmdline | cut -d'=' -f2)"
			update_xiaomi_bootenv "$mtd" || logger -t uboot_env "boot flag repair failed for $mtd"
			;;
	esac
}

start() {
	boot "$@"
}
