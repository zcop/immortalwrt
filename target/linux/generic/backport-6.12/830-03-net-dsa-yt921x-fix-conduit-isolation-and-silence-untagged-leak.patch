From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Codex <codex@local>
Date: Mon, 23 Mar 2026 22:45:00 +0700
Subject: [PATCH] net: dsa: yt921x: fix conduit isolation and silence untagged leak

When switching a user port conduit between CPU ports, enforce the user-port
CPU retarget bits directly for old/new CPU ports to avoid stale directional
isolation state on mixed dual-conduit boards.

Also silence noisy primary-conduit warnings for untagged flooded copies seen
while the secondary conduit is active; keep a debug-gated trace instead and
drop those frames.

Signed-off-by: Codex <codex@local>
---
 drivers/net/dsa/yt921x.c | 8 ++++++++
 net/dsa/tag_yt921x.c     | 9 ++++++---
 2 files changed, 14 insertions(+), 3 deletions(-)

--- a/drivers/net/dsa/yt921x.c
+++ b/drivers/net/dsa/yt921x.c
@@ -4920,6 +4920,14 @@ yt921x_dsa_port_change_conduit(struct ds
 
 	res = yt921x_userport_cpu_isolation_set(priv, port, new_cpu_port);
+	if (!res && new_cpu_port != old_cpu_port)
+		/* Ensure the moved user port always unblocks new CPU and blocks old
+		 * CPU explicitly, even if prior state was non-canonical.
+		 */
+		res = yt921x_reg_update_bits(priv, YT921X_PORTn_ISOLATION(port),
+					     BIT(old_cpu_port) | BIT(new_cpu_port),
+					     BIT(old_cpu_port));
+
 	if (!res && new_cpu_port != old_cpu_port)
 		res = yt921x_reg_read(priv, YT921X_PORTn_ISOLATION(new_cpu_port),
 				      &val);
--- a/net/dsa/tag_yt921x.c
+++ b/net/dsa/tag_yt921x.c
@@ -190,10 +190,13 @@ yt921x_tag_rcv(struct sk_buff *skb, stru
 			}
 		}
 
-		dev_warn_ratelimited(&netdev->dev,
-				     "Unexpected EtherType 0x%04x ingress=%s cpu_dp=%d\n",
-				     ntohs(tag[0]), netdev->name,
-				     cpu_dp ? cpu_dp->index : -1);
+		if (IS_ENABLED(CONFIG_NET_DSA_YT921X_DEBUG) && net_ratelimit())
+			netdev_info(netdev,
+				    "YT_DROP untagged ingress=%s cpu_dp=%d etype=0x%04x\n",
+				    netdev->name,
+				    cpu_dp ? cpu_dp->index : -1,
+				    ntohs(tag[0]));
+
 		return NULL;
 	}
 
