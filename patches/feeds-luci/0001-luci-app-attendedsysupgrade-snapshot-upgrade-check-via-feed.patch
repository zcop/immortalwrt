+function getVersionRepoBase(apk_repos, opkg_feeds, target)
+{
+	if (!target)
+		return null;
+
+	const marker = `/targets/${target}/`;
+	const parseLines = function(raw, opkgStyle) {
+		if (!raw)
+			return null;
+
+		for (const ln of raw.split('\n')) {
+			const line = ln.trim();
+			if (!line || line.startsWith('#'))
+				continue;
+
+			let url = line;
+			if (opkgStyle) {
+				const fields = line.split(/\s+/);
+				url = fields[fields.length - 1];
+			}
+
+			const idx = url.indexOf(marker);
+			if (idx > 0)
+				return url.substring(0, idx);
+		}
+
+		return null;
+	};
+
+	return parseLines(apk_repos, false) || parseLines(opkg_feeds, true);
+}
 
